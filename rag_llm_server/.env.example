# 火山引擎 AK/SK（OpenAPI 签名用，也可写在 scenes/Custom.json 的 AccountConfig）
VOLC_ACCESS_KEY=<your-volc-access-key>
VOLC_SECRET_KEY=<your-volc-secret-key>

# 方舟推理接入点（在火山方舟控制台创建，模型选 Doubao-pro/1.5/1.6 等）
# CustomLLM 模式下，后端 /api/chat_callback 转发方舟时使用此接入点作为 model
ARK_ENDPOINT_ID=<your-ark-endpoint-id>
ARK_API_KEY=<your-ark-api-key>

# RTC 应用配置（也可写在 scenes/Custom.json 的 RTCConfig）
RTC_APP_ID=<your-rtc-app-id>
RTC_APP_KEY=<your-rtc-app-key>

# 本地服务的公网地址（火山 RTC 云端必须能访问到这里）
# 开发时请用 ngrok 等内网穿透工具，或者部署到公网服务器
# 启动时会把该地址自动注入到 scenes 中 CustomLLM 场景的 LLMConfig.Url
SERVER_URL=https://<your-ngrok-domain>.ngrok-free.dev

# 可选：CustomLLM 回调鉴权 Token，留空则不校验
# 配置后，火山回调时需携带 Authorization: Bearer <此token>
# CHAT_CALLBACK_TOKEN=<your-callback-token>
